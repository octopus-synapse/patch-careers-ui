{
  "name": "client",
  "version": "0.0.1",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "android:no-bundler": "expo run:android --no-bundler",
    "ios": "expo run:ios",
    "ios:no-bundler": "expo run:ios --no-bundler",
    "web": "expo start --web --dev-client",
    "dev:android": "concurrently --kill-others-on-fail -n metro,android -c blue,green \"pnpm start\" \"wait-on tcp:8081 && pnpm android:no-bundler\"",
    "dev:ios": "concurrently --kill-others-on-fail -n metro,ios -c blue,green \"pnpm start\" \"wait-on tcp:8081 && pnpm ios:no-bundler\"",
    "eas-build-post-install": "cd ../../ && node tools/scripts/eas-build-post-install.mjs . apps/client"
  },
  "dependencies": {
    "@expo/metro-config": "~54.0.9",
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.1.1",
    "@patch-careers/api-client": "workspace:^",
    "@patch-careers/auth": "workspace:^",
    "@patch-careers/i18n": "workspace:^",
    "@patch-careers/state": "workspace:^",
    "@patch-careers/storage": "workspace:^",
    "@patch-careers/tokens": "workspace:^",
    "@patch-careers/ui": "workspace:^",
    "@react-native-community/netinfo": "^11.4.1",
    "@tamagui/animations-react-native": "1.144.4",
    "@tamagui/babel-plugin": "1.144.4",
    "@tamagui/config": "1.144.4",
    "@tamagui/core": "1.144.4",
    "@tamagui/portal": "1.144.4",
    "@tamagui/sheet": "1.144.4",
    "@tamagui/toast": "1.144.4",
    "@tanstack/react-query": "^5.62.0",
    "burnt": "^0.13.0",
    "expo": "~54.0.0",
    "expo-auth-session": "~7.0.8",
    "expo-constants": "~18.0.9",
    "expo-haptics": "~15.0.7",
    "expo-image-picker": "~17.0.8",
    "expo-linking": "~8.0.8",
    "expo-local-authentication": "~17.0.7",
    "expo-notifications": "~0.32.13",
    "expo-router": "~6.0.13",
    "expo-secure-store": "~15.0.7",
    "expo-sharing": "~14.0.7",
    "expo-splash-screen": "~31.0.11",
    "expo-status-bar": "~3.0.8",
    "expo-system-ui": "~6.0.8",
    "expo-web-browser": "~15.0.8",
    "lucide-react-native": "^1.16.0",
    "metro-config": "~0.83.0",
    "metro-resolver": "~0.83.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-mmkv": "^3.0.0",
    "react-native-reanimated": "~4.1.2",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-sse": "^1.2.1",
    "react-native-svg": "15.12.1",
    "react-native-svg-transformer": "~1.5.1",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.13.5",
    "react-native-worklets": "0.8.3",
    "tamagui": "1.144.4",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "wait-on": "^9.0.10"
  }
}
