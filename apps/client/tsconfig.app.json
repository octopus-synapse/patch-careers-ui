{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "composite": true,
    "types": ["node"],
    "jsx": "react-jsx"
  },
  "files": ["../../node_modules/@nx/expo/typings/svg.d.ts"],
  "exclude": [
    "node_modules",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/*.test.tsx",
    "**/*.spec.tsx",
    "**/*.test.js",
    "**/*.spec.js"
  ],
  "include": [
    "src/app/**/*.ts",
    "src/app/**/*.tsx",
    "src/components/**/*.ts",
    "src/components/**/*.tsx",
    "src/config/**/*.ts",
    "src/config/**/*.tsx",
    "src/features/**/*.ts",
    "src/features/**/*.tsx",
    "src/navigation/**/*.ts",
    "src/navigation/**/*.tsx",
    "src/providers/**/*.ts",
    "src/providers/**/*.tsx",
    "tamagui.config.ts",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "references": [
    {
      "path": "../../packages/ui"
    },
    {
      "path": "../../packages/storage"
    },
    {
      "path": "../../packages/state"
    },
    {
      "path": "../../packages/i18n"
    },
    {
      "path": "../../packages/auth"
    },
    {
      "path": "../../packages/api-client"
    },
    {
      "path": "../../packages/tokens"
    }
  ]
}
