{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "extends": ["@octopus-synapse/biome-config/biome.json"],
  "files": {
    "includes": [
      "!**/.svelte-kit",
      "!**/.turbo",
      "!**/test-results",
      "!**/playwright-report",
      "!packages/api-client/src/generated",
      "!**/*.svelte",
      "!**/*.html",
      "!**/*.css"
    ]
  },
  "linter": {
    "rules": {
      "suspicious": {
        "noExplicitAny": "error"
      },
      "style": {
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "paths": {
              "api-client/client": "Hand-rolled requests are banned. Consume the generated `createXxx` hooks / `xxx()` functions from `api-client/generated/api/*` instead."
            }
          }
        }
      }
    }
  }
}
