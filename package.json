{
  "name": "patch-careers-ui",
  "version": "0.0.3",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.12",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run check",
    "typecheck": "turbo run check",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "turbo run test",
    "test:e2e": "cd apps/web && bun run test:e2e",
    "dev": "turbo run dev",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@commitlint/cli": "^20",
    "@commitlint/config-conventional": "^20",
    "@commitlint/types": "^20",
    "@octopus-synapse/biome-config": "^1",
    "@octopus-synapse/commitlint-config": "^1",
    "@octopus-synapse/precommit": "^1",
    "@octopus-synapse/release-cli": "^1.6.0",
    "@types/bun": "latest",
    "husky": "^9",
    "turbo": "^2"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
