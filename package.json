{
  "name": "patch-careers-ui",
  "version": "0.0.3",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "nx run-many -t test",
    "build": "nx run-many -t build",
    "typecheck": "nx run-many -t typecheck",
    "graph": "nx graph",
    "affected": "nx affected",
    "android": "pnpm --filter client android",
    "ios": "pnpm --filter client ios",
    "dev:android": "pnpm --filter client dev:android",
    "dev:ios": "pnpm --filter client dev:ios",
    "metro": "pnpm --filter client start",
    "prepare": "husky"
  },
  "devDependencies": {
    "@babel/runtime": "~7.27.6",
    "@biomejs/biome": "^2.4.13",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@commitlint/types": "^19.8.1",
    "@expo/cli": "~54.0.16",
    "@nx/expo": "^22.7.3",
    "@nx/js": "^22.7.3",
    "@nx/react": "^22.7.3",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/node": "^20.0.0",
    "@types/react": "^19.1.0",
    "@vitest/coverage-v8": "^2.1.9",
    "babel-preset-expo": "~54.0.7",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "metro-config": "~0.83.0",
    "metro-resolver": "~0.83.0",
    "nx": "^22.7.3",
    "tslib": "^2.3.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  }
}
