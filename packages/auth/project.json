{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "auth",
  "sourceRoot": "packages/auth/src",
  "projectType": "library",
  "tags": ["scope:shared", "type:auth"],
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --coverage",
        "cwd": "packages/auth"
      },
      "cache": true,
      "inputs": ["default", "^production"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "biome check .",
        "cwd": "packages/auth"
      },
      "cache": true,
      "inputs": ["default", "{workspaceRoot}/biome.json"]
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p tsconfig.json",
        "cwd": "packages/auth"
      },
      "cache": true,
      "inputs": ["default", "^production"]
    }
  }
}
