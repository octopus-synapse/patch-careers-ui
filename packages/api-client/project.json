{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "api-client",
  "sourceRoot": "packages/api-client/src",
  "projectType": "library",
  "tags": ["scope:shared", "type:api-client"],
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run",
        "cwd": "packages/api-client"
      },
      "cache": true,
      "inputs": ["default", "^production"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "biome check .",
        "cwd": "packages/api-client"
      },
      "cache": true,
      "inputs": ["default", "{workspaceRoot}/biome.json"]
    },
    "sdk:generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "kubb generate && tsx scripts/post-kubb.ts",
        "cwd": "packages/api-client"
      },
      "cache": false
    }
  }
}
